@page
@model FirmovaAI.Pages.IndexModel
@{
    ViewData["Title"] = "Nova AI Panel";
}

<div class="container py-4">
    <div class="card shadow-sm border-0" style="max-width: 900px; margin: 0 auto; border-radius: 18px;">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="mb-0">Nova AI Panel</h1>

                <form method="post" asp-page-handler="Temizle">
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Sohbeti Temizle</button>
                </form>
            </div>

            <p class="text-muted mb-4">
                Nova ile yazabilir ya da konuşabilirsin. Asistan modu açıksa “Nova” diyerek komut verebilirsin.
            </p>

            <form method="post" id="soruForm">
                <div class="mb-3">
                    <textarea asp-for="Soru" id="soruKutusu" class="form-control" rows="3"
                              placeholder="Örnek: carileri listele"></textarea>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-dark px-4">Sor</button>
                    <button type="button" id="konusButonu" class="btn btn-outline-primary">🎤 Tek Konuşma</button>
                    <button type="button" id="asistanModuButonu" class="btn btn-outline-warning">🟡 Asistan Kapalı</button>
                    <button type="button" id="sesOkuButonu" class="btn btn-outline-success">🔊 Oku</button>
                    <button type="button" id="sesiDurdurButonu" class="btn btn-outline-danger">⏹ Durdur</button>
                </div>

                <div id="sesDurumu" class="mt-2 text-muted small"></div>
            </form>

            <hr class="my-4" />

            @if (Model.Mesajlar.Count == 0)
            {
                <div class="alert alert-light border">
                    Henüz sohbet yok. “Nova çalışanları listele” diyerek başlayabilirsin.
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var mesaj in Model.Mesajlar)
                    {
                        if (mesaj.Tip == "user")
                        {
                            <div class="d-flex justify-content-end">
                                <div class="p-3 border rounded shadow-sm" style="background:#e9f7ef; max-width:75%;">
                                    <div class="fw-semibold mb-1">Sen</div>
                                    <div style="white-space:pre-line;">@mesaj.Metin</div>
                                    <div class="text-muted small mt-2">@mesaj.Tarih.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-start">
                                <div class="p-3 border rounded shadow-sm ai-cevap-karti" style="background:#f8f9fa; max-width:75%;">
                                    <div class="fw-semibold mb-1">Nova</div>
                                    <div class="ai-cevap-metin" style="white-space:pre-line;">@mesaj.Metin</div>
                                    <div class="text-muted small mt-2">@mesaj.Tarih.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    const konusButonu = document.getElementById("konusButonu");
    const asistanModuButonu = document.getElementById("asistanModuButonu");
    const sesOkuButonu = document.getElementById("sesOkuButonu");
    const sesiDurdurButonu = document.getElementById("sesiDurdurButonu");
    const soruKutusu = document.getElementById("soruKutusu");
    const sesDurumu = document.getElementById("sesDurumu");
    const soruForm = document.getElementById("soruForm");

    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    let recognition;
    let asistanAcik = false;
    let wakeMode = false;
    let commandMode = false;

    function normalize(text) {
        return (text || "")
            .toLowerCase()
            .trim()
            .replaceAll("ı", "i")
            .replaceAll("ğ", "g")
            .replaceAll("ü", "u")
            .replaceAll("ş", "s")
            .replaceAll("ö", "o")
            .replaceAll("ç", "c");
    }

    function sesliOku(metin) {
        if (!('speechSynthesis' in window)) return;
        window.speechSynthesis.cancel();

        const u = new SpeechSynthesisUtterance(metin);
        u.lang = "tr-TR";
        u.rate = 0.97;
        u.pitch = 1.03;
        u.volume = 1;

        speechSynthesis.speak(u);
    }

    function sonCevap() {
        const list = document.querySelectorAll(".ai-cevap-metin");
        if (list.length === 0) return "";
        return list[list.length - 1].innerText;
    }

    function wakeVarMi(text) {
        const t = normalize(text);
        return t.includes("nova");
    }

    function komutAyikla(text) {
        const original = (text || "").trim();
        const t = normalize(original);

        const varyasyonlar = ["hey nova", "ey nova", "hei nova", "nova"];

        for (const v of varyasyonlar) {
            const i = t.indexOf(v);
            if (i >= 0) {
                return original.substring(i + v.length).trim();
            }
        }
        return "";
    }

    function sadeceNovaMi(text) {
        const t = normalize(text);
        return t === "nova" || t === "hey nova" || t === "ey nova" || t === "hei nova";
    }

    function sayiBul(text, regex) {
        const match = text.match(regex);
        return match ? match[1] : null;
    }

    function maddeListesiBul(text) {
        const satirlar = text.split("\n").map(x => x.trim()).filter(x => x.startsWith("- "));
        return satirlar.map(x => x.replace("- ", "").trim());
    }

    function dogalSesMetniOlustur(cevap) {
        if (!cevap || cevap.trim() === "") {
            return "Şu anda okunacak bir cevap bulamadım.";
        }

        const temiz = cevap.trim();

        if (temiz.includes("Toplam çalışan sayısı:")) {
            const toplam = sayiBul(temiz, /Toplam çalışan sayısı:\s*(\d+)/i);
            const gosterilen = sayiBul(temiz, /Gösterilen:\s*(\d+)/i);
            const isimler = maddeListesiBul(temiz);

            let metin = "";
            if (toplam) metin += `Toplam ${toplam} çalışan görünüyor. `;
            if (isimler.length > 0) metin += `İlk çalışanlar şöyle: ${isimler.slice(0, 3).join(", ")}. `;
            if (toplam && gosterilen && parseInt(toplam) > parseInt(gosterilen)) metin += "İstersen kalan çalışanları da listeleyebilirim.";
            return metin.trim();
        }

        if (temiz.includes("Toplam cari sayısı:")) {
            const toplam = sayiBul(temiz, /Toplam cari sayısı:\s*(\d+)/i);
            const gosterilen = sayiBul(temiz, /Gösterilen:\s*(\d+)/i);
            const isimler = maddeListesiBul(temiz);

            let metin = "";
            if (toplam) metin += `Toplam ${toplam} cari kayıt görünüyor. `;
            if (isimler.length > 0) metin += `Öne çıkan kayıtlar: ${isimler.slice(0, 3).join(", ")}. `;
            if (toplam && gosterilen && parseInt(toplam) > parseInt(gosterilen)) metin += "İstersen daha fazlasını da gösterebilirim.";
            return metin.trim();
        }

        if (temiz.includes("Toplam stok ürün sayısı:")) {
            const toplam = sayiBul(temiz, /Toplam stok ürün sayısı:\s*(\d+)/i);
            const gosterilen = sayiBul(temiz, /Gösterilen:\s*(\d+)/i);
            const urunler = maddeListesiBul(temiz);

            let metin = "";
            if (toplam) metin += `Toplam ${toplam} stok ürünü görünüyor. `;
            if (urunler.length > 0) metin += `İlk ürünler: ${urunler.slice(0, 3).join(", ")}. `;
            if (toplam && gosterilen && parseInt(toplam) > parseInt(gosterilen)) metin += "İstersen diğer ürünleri de listeleyebilirim.";
            return metin.trim();
        }

        if (temiz.includes("Tam eşleşme bulunamadı")) {
            const satirlar = maddeListesiBul(temiz);
            if (satirlar.length > 0) {
                return `Tam eşleşme bulamadım. Ama benzer sonuçlar var. Örneğin ${satirlar.slice(0, 3).join(", ")}.`;
            }
            return "Tam eşleşme bulamadım.";
        }

        if (temiz.includes("Tam eşleşen")) {
            const satirlar = maddeListesiBul(temiz);
            if (satirlar.length > 0) {
                return `Evet, eşleşen kayıtları buldum. ${satirlar.slice(0, 3).join(", ")}.`;
            }
            return "Evet, eşleşen kayıt bulundu.";
        }

        if (temiz.includes("Kayıtlı çalışan bulunamadı"))
            return "Şu anda kayıtlı çalışan görünmüyor.";

        if (temiz.includes("Kayıtlı cari bulunamadı"))
            return "Şu anda kayıtlı cari görünmüyor.";

        if (temiz.includes("Kayıtlı stok ürünü bulunamadı"))
            return "Şu anda kayıtlı stok ürünü görünmüyor.";

        if (temiz.includes("Kasa hareket tablosu"))
            return "Kasa hareket bilgisine şu an erişemiyorum.";

        if (temiz.length > 220) {
            return temiz.substring(0, 220).trim() + "...";
        }

        return temiz;
    }

    function novaOnYanitiUret(komut) {
        const t = normalize(komut);

        const girisler = [
            "Tamam, hemen kontrol ediyorum.",
            "Elbette, senin için bakıyorum.",
            "Bir saniye, hemen bakıyorum.",
            "Hemen ilgileniyorum.",
            "Tabii ki, şimdi kontrol ediyorum."
        ];

        const sec = girisler[Math.floor(Math.random() * girisler.length)];

        if (t.includes("calisan"))
            return sec + " Çalışan bilgilerine bakıyorum.";

        if (t.includes("cari") || t.includes("musteri") || t.includes("firma"))
            return sec + " Cari kayıtlarını kontrol ediyorum.";

        if (t.includes("stok") || t.includes("urun"))
            return sec + " Stok bilgilerini inceliyorum.";

        if (t.includes("kasa"))
            return sec + " Kasa tarafına göz atıyorum.";

        if (t.includes("avans"))
            return sec + " Avans bilgilerini kontrol ediyorum.";

        if (t.includes("maas") || t.includes("maaş"))
            return sec + " Maaş kayıtlarına bakıyorum.";

        return sec;
    }

    konusButonu.onclick = () => {
        recognition.start();
        sesDurumu.innerText = "Dinleniyor...";
    };

    asistanModuButonu.onclick = () => {
        asistanAcik = !asistanAcik;

        if (asistanAcik) {
            wakeMode = true;
            commandMode = false;
            asistanModuButonu.innerText = "🟢 Asistan Açık";
            sesDurumu.innerText = "Nova hazır. 'Nova' diyebilirsin.";
            recognition.start();
        } else {
            wakeMode = false;
            commandMode = false;
            asistanModuButonu.innerText = "🟡 Asistan Kapalı";
            try { recognition.stop(); } catch { }
        }
    };

    sesOkuButonu.onclick = () => {
        const cevap = sonCevap();
        const sesMetni = dogalSesMetniOlustur(cevap);
        sesliOku(sesMetni);
    };

    sesiDurdurButonu.onclick = () => {
        speechSynthesis.cancel();
    };

    if (SpeechRecognition) {
        recognition = new SpeechRecognition();
        recognition.lang = "tr-TR";
        recognition.continuous = false;
        recognition.interimResults = false;

        recognition.onresult = (e) => {
            let text = e.results[0][0].transcript;

            if (!asistanAcik) {
                soruKutusu.value = text;
                sesDurumu.innerText = "Konuşma metne çevrildi. Gönderiliyor...";
                soruForm.submit();
                return;
            }

            if (wakeVarMi(text)) {
                let cmd = komutAyikla(text);
                if (cmd) {
                    wakeMode = false;
                    commandMode = false;
                    soruKutusu.value = cmd;
                    sesDurumu.innerText = "Komut alındı. Nova düşünüyor...";
                    sesliOku(novaOnYanitiUret(cmd));
                    setTimeout(() => soruForm.submit(), 700);
                    return;
                }
            }

            if (wakeMode && sadeceNovaMi(text)) {
                wakeMode = false;
                commandMode = true;
                sesDurumu.innerText = "Nova seni dinliyor...";
                sesliOku("Dinliyorum");
                setTimeout(() => {
                    try { recognition.start(); } catch { }
                }, 850);
                return;
            }

            if (commandMode) {
                commandMode = false;
                soruKutusu.value = text;
                sesDurumu.innerText = "Komut alındı. Nova düşünüyor...";
                sesliOku(novaOnYanitiUret(text));
                setTimeout(() => soruForm.submit(), 700);
                return;
            }

            sesDurumu.innerText = "Nova hazır. 'Nova' diyebilirsin.";
        };

        recognition.onend = () => {
            if (asistanAcik) {
                setTimeout(() => {
                    try { recognition.start(); } catch { }
                }, 500);
            }
        };

        recognition.onerror = (e) => {
            sesDurumu.innerText = "Ses tanıma hatası: " + e.error;
        };
    } else {
        konusButonu.disabled = true;
        asistanModuButonu.disabled = true;
        sesDurumu.innerText = "Bu tarayıcı ses tanımayı desteklemiyor.";
    }

    window.onload = () => {
        const c = sonCevap();
        if (c) {
            sesliOku(dogalSesMetniOlustur(c));
        }
    };
</script>
}