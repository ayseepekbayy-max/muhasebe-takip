@page "{id:int}"
@using MuhasebeTakip2.App.Models
@model MuhasebeTakip2.App.Pages.Stoklar.Detay.IndexModel

@if (Model.Urun == null)
{
  <h2>Ürün bulunamadı</h2>
  return;
}

<h1>Stok Detay</h1>

<p>
  <a class="btn btn-outline-dark btn-sm" href="/Stoklar">← Stok</a>
</p>

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:900px;">
  <h3 style="margin-bottom:6px;">@Model.Urun.Ad</h3>
  <div><b>Kod:</b> @(string.IsNullOrWhiteSpace(Model.Urun.Kod) ? "-" : Model.Urun.Kod)</div>
  <div><b>Birim:</b> @Model.Urun.Birim</div>

  <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:12px;">
    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Toplam Giriş</b><div style="font-size:18px;">@Model.ToplamGiris</div>
    </div>
    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Toplam Çıkış</b><div style="font-size:18px;">@Model.ToplamCikis</div>
    </div>
    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Kalan Stok</b><div style="font-size:18px;">@Model.Stok</div>
    </div>
  </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Hata))
{
  <div style="color:red; margin:10px 0;">
    @Model.Hata
  </div>
}

@if (!ViewData.ModelState.IsValid)
{
  <div style="color:red; margin:10px 0;">
    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    { <div>@err.ErrorMessage</div> }
  </div>
}

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:900px;">
  <h3>Hareket Ekle</h3>

  <form method="post">
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <div style="min-width:180px;">
        <label><b>Tarih</b></label><br />
        <input asp-for="Tarih" type="date" style="padding:8px; width:180px;" />
      </div>

      <div style="min-width:180px;">
        <label><b>Miktar</b></label><br />
        <input asp-for="Miktar" type="number" step="0.01" style="padding:8px; width:180px;" />
      </div>

      <div style="flex:1; min-width:260px;">
        <label><b>Açıklama</b></label><br />
        <input asp-for="Aciklama" style="padding:8px; width:100%;" />
      </div>
    </div>

    <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
      <button type="submit" asp-page-handler="Giris" class="btn btn-outline-dark btn-sm">Stok Giriş</button>
      <button type="submit" asp-page-handler="Cikis" class="btn btn-dark btn-sm">Stok Çıkış</button>
    </div>
  </form>
</div>

<h3>Hareketler</h3>

<table style="width:100%; border-collapse:collapse;">
  <thead>
    <tr>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tarih</th>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tip</th>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Miktar</th>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
      <th style="border-bottom:1px solid #555; padding:8px; width:120px;">İşlem</th>
    </tr>
  </thead>
  <tbody>
    @if (Model.Hareketler.Count == 0)
    {
      <tr><td colspan="5" style="padding:8px;">Henüz hareket yok.</td></tr>
    }
    else
    {
      @foreach (var h in Model.Hareketler)
      {
        <tr>
          <td style="border-bottom:1px solid #333; padding:8px;">@h.Tarih.ToShortDateString()</td>
          <td style="border-bottom:1px solid #333; padding:8px;">@(h.Tip == StokHareketTipi.Giris ? "Giriş" : "Çıkış")</td>
          <td style="border-bottom:1px solid #333; padding:8px;">@h.Miktar</td>
          <td style="border-bottom:1px solid #333; padding:8px;">@h.Aciklama</td>
          <td style="border-bottom:1px solid #333; padding:8px;">
            <form method="post" asp-page-handler="Sil" style="display:inline;"
                  onsubmit="return confirm('Hareket silinsin mi?');">
              <input type="hidden" name="id2" value="@h.Id" />
              <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
            </form>
          </td>
        </tr>
      }
    }
  </tbody>
</table>