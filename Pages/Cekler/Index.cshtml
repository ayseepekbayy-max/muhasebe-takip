@page "/Cekler"
@model MuhasebeTakip2.App.Pages.Cekler.IndexModel

<h1>Çekler</h1>

@if (!string.IsNullOrWhiteSpace(Model.Mesaj))
{
    <div style="color:green; margin:10px 0;">@Model.Mesaj</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Hata))
{
    <div style="color:red; margin:10px 0;">@Model.Hata</div>
}

<div style="border:1px solid #444; border-radius:12px; padding:16px; margin-bottom:20px; background:white; max-width:850px;">
    <h3>Yeni Çek Ekle</h3>

    <form method="post" enctype="multipart/form-data">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
            <div>
                <label><b>No</b></label><br />
                <input asp-for="YeniCek.No" style="width:100%; padding:8px;" />
            </div>

            <div>
                <label><b>Tarih</b></label><br />
                <input asp-for="YeniCek.Tarih" type="date" style="width:100%; padding:8px;" />
            </div>

            <div>
                <label><b>Tutar</b></label><br />
                <input asp-for="YeniCek.Tutar" style="width:100%; padding:8px;" />
            </div>

            <div>
                <label><b>Tip</b></label><br />
                <select asp-for="YeniCek.Tip" style="width:100%; padding:8px;">
                    <option value="1">Alınacak</option>
                    <option value="2">Ödenecek</option>
                </select>
            </div>
        </div>

        <div style="margin-top:12px;">
            <label><b>Açıklama</b></label><br />
            <input asp-for="YeniCek.Aciklama" style="width:100%; padding:8px;" />
        </div>

        <div style="margin-top:12px;">
            <label><b>Çek Görseli</b></label><br />
            <input asp-for="CekResmi" type="file" accept=".jpg,.jpeg,.png,.webp" />
        </div>

        <div style="margin-top:16px;">
            <button type="submit" class="btn btn-dark btn-sm">Kaydet</button>
        </div>
    </form>
</div>

<h3>Alınacak Çekler</h3>
<table style="width:100%; border-collapse:collapse; margin-bottom:24px;">
    <thead>
        <tr>
            <th style="padding:8px;">No</th>
            <th style="padding:8px;">Tarih</th>
            <th style="padding:8px;">Tutar</th>
            <th style="padding:8px;">Açıklama</th>
            <th style="padding:8px;">Görsel</th>
            <th style="padding:8px;">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Alinacaklar.Count == 0)
        {
            <tr><td colspan="6" style="padding:8px;">Kayıt yok.</td></tr>
        }
        else
        {
            @foreach (var c in Model.Alinacaklar)
            {
                <tr>
                    <td style="padding:8px;">@c.No</td>
                    <td style="padding:8px;">@c.Tarih.ToString("dd.MM.yyyy")</td>
                    <td style="padding:8px;">@c.Tutar</td>
                    <td style="padding:8px;">@c.Aciklama</td>
                    <td style="padding:8px;">
                        @if (!string.IsNullOrWhiteSpace(c.ResimYolu))
                        {
                            <a href="@c.ResimYolu" target="_blank">
                                <img src="@c.ResimYolu" style="width:60px; height:40px; object-fit:cover; border-radius:6px;" />
                            </a>
                        }
                    </td>
                    <td style="padding:8px;">
                        <form method="post" asp-page-handler="Sil" style="display:inline;" onsubmit="return confirm('Kayıt silinsin mi?');">
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<h3>Ödenecek Çekler</h3>
<table style="width:100%; border-collapse:collapse;">
    <thead>
        <tr>
            <th style="padding:8px;">No</th>
            <th style="padding:8px;">Tarih</th>
            <th style="padding:8px;">Tutar</th>
            <th style="padding:8px;">Açıklama</th>
            <th style="padding:8px;">Görsel</th>
            <th style="padding:8px;">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Odenecekler.Count == 0)
        {
            <tr><td colspan="6" style="padding:8px;">Kayıt yok.</td></tr>
        }
        else
        {
            @foreach (var c in Model.Odenecekler)
            {
                <tr>
                    <td style="padding:8px;">@c.No</td>
                    <td style="padding:8px;">@c.Tarih.ToString("dd.MM.yyyy")</td>
                    <td style="padding:8px;">@c.Tutar</td>
                    <td style="padding:8px;">@c.Aciklama</td>
                    <td style="padding:8px;">
                        @if (!string.IsNullOrWhiteSpace(c.ResimYolu))
                        {
                            <a href="@c.ResimYolu" target="_blank">
                                <img src="@c.ResimYolu" style="width:60px; height:40px; object-fit:cover; border-radius:6px;" />
                            </a>
                        }
                    </td>
                    <td style="padding:8px;">
                        <form method="post" asp-page-handler="Sil" style="display:inline;" onsubmit="return confirm('Kayıt silinsin mi?');">
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>