@page
@model MuhasebeTakip2.App.Pages.LoginModel
@{
    ViewData["Title"] = "Giriş";
}

<div style="max-width:420px; margin:40px auto; border:1px solid #444; border-radius:12px; padding:24px;">
    <h1 style="margin-bottom:20px;">Giriş Yap</h1>

    @if (!string.IsNullOrEmpty(Model.Hata))
    {
        <div style="color:#b00020; background:#ffeaea; border:1px solid #f0b5b5; padding:10px; border-radius:8px; margin-bottom:15px;">
            @Model.Hata
        </div>
    }

    <form method="post">
        <div style="margin-bottom:14px;">
            <label><b>Kullanıcı Adı</b></label><br />
            <input asp-for="KullaniciAdi" style="width:100%; padding:10px; border:1px solid #ccc; border-radius:8px;" />
        </div>

        <div style="margin-bottom:18px;">
            <label><b>Şifre</b></label><br />
            <input asp-for="Sifre" type="password" style="width:100%; padding:10px; border:1px solid #ccc; border-radius:8px;" />
        </div>

        <button type="submit" class="btn btn-dark w-100">Giriş Yap</button>
    </form>
</div>