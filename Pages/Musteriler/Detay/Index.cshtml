@page "{id:int}"
@model MuhasebeTakip2.App.Pages.Musteriler.Detay.IndexModel

<h1>Müşteri Detay</h1>

@if (!string.IsNullOrWhiteSpace(Model.Hata))
{
    <div style="color:red; margin:10px 0;">
        @Model.Hata
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Mesaj))
{
    <div style="color:green; margin:10px 0;">
        @Model.Mesaj
    </div>
}

@if (Model.Musteri == null)
{
    <div style="color:red; margin-top:15px;">Müşteri bulunamadı.</div>
}
else
{
    <div style="border:1px solid #444; border-radius:12px; padding:20px; margin:18px 0; max-width:1100px;">
        <h3 style="margin-top:0; margin-bottom:18px;">@Model.Musteri.AdSoyad</h3>

        <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <div style="border:1px solid #444; border-radius:10px; padding:14px; min-width:240px; flex:1;">
                <div style="font-weight:bold; margin-bottom:6px;">Ad Soyad</div>
                <div>@(string.IsNullOrWhiteSpace(Model.Musteri.AdSoyad) ? "-" : Model.Musteri.AdSoyad)</div>
            </div>

            <div style="border:1px solid #444; border-radius:10px; padding:14px; min-width:240px; flex:1;">
                <div style="font-weight:bold; margin-bottom:6px;">Telefon</div>
                <div>@(string.IsNullOrWhiteSpace(Model.Musteri.Telefon) ? "-" : Model.Musteri.Telefon)</div>
            </div>
        </div>

        <div style="margin-top:16px; border:1px solid #444; border-radius:10px; padding:14px;">
            <div style="font-weight:bold; margin-bottom:6px;">Adres</div>
            <div>@(string.IsNullOrWhiteSpace(Model.Musteri.Adres) ? "-" : Model.Musteri.Adres)</div>
        </div>

        <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:18px;">
            <div style="border:1px solid #444; border-radius:10px; padding:14px; min-width:220px;">
                <div style="font-weight:bold; margin-bottom:6px;">Toplam Gelir</div>
                <div style="font-size:20px;">@Model.ToplamGelir</div>
            </div>

            <div style="border:1px solid #444; border-radius:10px; padding:14px; min-width:220px;">
                <div style="font-weight:bold; margin-bottom:6px;">Toplam Masraf</div>
                <div style="font-size:20px;">@Model.ToplamMasraf</div>
            </div>

            <div style="border:1px solid #444; border-radius:10px; padding:14px; min-width:220px;">
                <div style="font-weight:bold; margin-bottom:6px;">Net Durum</div>
                <div style="font-size:20px;">@Model.NetTutar</div>
            </div>
        </div>
    </div>

    <div style="display:flex; gap:20px; flex-wrap:wrap; margin:20px 0; max-width:1100px;">
        <div style="flex:1; min-width:320px; border:1px solid #444; border-radius:12px; padding:18px;">
            <h3 style="margin-top:0;">Yeni İş Ekle</h3>

            <form method="post" asp-page-handler="IsEkle">
                <div style="margin-bottom:10px;">
                    <label><b>Tarih</b></label><br />
                    <input asp-for="YeniIsTarih" type="date" style="width:100%; padding:8px;" />
                </div>

                <div style="margin-bottom:10px;">
                    <label><b>İş Adı</b></label><br />
                    <input asp-for="YeniIsAdi" style="width:100%; padding:8px;" />
                </div>

                <div style="margin-bottom:10px;">
                    <label><b>Gelir</b></label><br />
                    <input asp-for="YeniIsGelir" type="number" step="0.01" style="width:100%; padding:8px;" />
                </div>

                <button type="submit" class="btn btn-dark btn-sm">İş Ekle</button>
            </form>
        </div>

        <div style="flex:1; min-width:320px; border:1px solid #444; border-radius:12px; padding:18px;">
            <h3 style="margin-top:0;">Masraf Ekle</h3>

            <form method="post" asp-page-handler="MasrafEkle">
                <div style="margin-bottom:10px;">
                    <label><b>İş Seç</b></label><br />
                    <select asp-for="MasrafIsId" style="width:100%; padding:8px;">
                        <option value="0">İş seçiniz</option>
                        @foreach (var isKaydi in Model.Isler)
                        {
                            <option value="@isKaydi.Id">@isKaydi.IsAdi</option>
                        }
                    </select>
                </div>

                <div style="margin-bottom:10px;">
                    <label><b>Tarih</b></label><br />
                    <input asp-for="YeniMasrafTarih" type="date" style="width:100%; padding:8px;" />
                </div>

                <div style="margin-bottom:10px;">
                    <label><b>Açıklama</b></label><br />
                    <input asp-for="YeniMasrafAciklama" style="width:100%; padding:8px;" />
                </div>

                <div style="margin-bottom:10px;">
                    <label><b>Tutar</b></label><br />
                    <input asp-for="YeniMasrafTutar" type="number" step="0.01" style="width:100%; padding:8px;" />
                </div>

                <button type="submit" class="btn btn-outline-dark btn-sm">Masraf Ekle</button>
            </form>
        </div>
    </div>

    <h3>İşler</h3>

    <div style="max-width:1100px;">
        @if (Model.Isler.Count == 0)
        {
            <div style="border:1px solid #444; border-radius:10px; padding:14px;">
                Henüz iş kaydı yok.
            </div>
        }
        else
        {
            @foreach (var isKaydi in Model.Isler)
            {
                var isToplamMasraf = isKaydi.Masraflar.Sum(x => x.Tutar);
                var isNet = isKaydi.Gelir - isToplamMasraf;

                <div style="border:1px solid #444; border-radius:12px; padding:18px; margin-bottom:16px;">
                    <div style="display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap;">
                        <div>
                            <div style="font-size:20px; font-weight:bold;">@isKaydi.IsAdi</div>
                            <div style="margin-top:6px;">Tarih: @isKaydi.Tarih.ToShortDateString()</div>
                        </div>

                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            <div style="border:1px solid #444; border-radius:8px; padding:10px; min-width:140px;">
                                <b>Gelir</b><br />
                                @isKaydi.Gelir
                            </div>

                            <div style="border:1px solid #444; border-radius:8px; padding:10px; min-width:140px;">
                                <b>Masraf</b><br />
                                @isToplamMasraf
                            </div>

                            <div style="border:1px solid #444; border-radius:8px; padding:10px; min-width:140px;">
                                <b>Net</b><br />
                                @isNet
                            </div>
                        </div>
                    </div>

                    <div style="margin-top:14px;">
                        <form method="post" asp-page-handler="IsSil" style="display:inline;"
                              onsubmit="return confirm('Bu iş silinirse bağlı masraflar da silinecek. Devam edilsin mi?');">
                            <input type="hidden" name="isId" value="@isKaydi.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">İşi Sil</button>
                        </form>
                    </div>

                    <div style="margin-top:16px;">
                        <h4>Masraflar</h4>

                        @if (isKaydi.Masraflar == null || isKaydi.Masraflar.Count == 0)
                        {
                            <div style="padding:8px 0;">Bu işe ait masraf yok.</div>
                        }
                        else
                        {
                            <table style="width:100%; border-collapse:collapse;">
                                <thead>
                                    <tr>
                                        <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tarih</th>
                                        <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
                                        <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tutar</th>
                                        <th style="border-bottom:1px solid #555; padding:8px; width:120px;">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var masraf in isKaydi.Masraflar.OrderByDescending(x => x.Tarih).ThenByDescending(x => x.Id))
                                    {
                                        <tr>
                                            <td style="border-bottom:1px solid #333; padding:8px;">@masraf.Tarih.ToShortDateString()</td>
                                            <td style="border-bottom:1px solid #333; padding:8px;">@masraf.Aciklama</td>
                                            <td style="border-bottom:1px solid #333; padding:8px;">@masraf.Tutar</td>
                                            <td style="border-bottom:1px solid #333; padding:8px;">
                                                <form method="post" asp-page-handler="MasrafSil" style="display:inline;"
                                                      onsubmit="return confirm('Masraf silinsin mi?');">
                                                    <input type="hidden" name="masrafId" value="@masraf.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }
        }
    </div>
}

<div style="margin-top:16px;">
    <a class="btn btn-outline-dark btn-sm" href="/Musteriler/Index">← Geri Dön</a>
</div>