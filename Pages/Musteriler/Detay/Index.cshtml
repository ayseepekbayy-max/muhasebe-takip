@page "{id:int}"
@model MuhasebeTakip2.App.Pages.Musteriler.Detay.IndexModel

@if (Model.Musteri == null)
{
  <h2>Müşteri bulunamadı</h2>
  return;
}

<h1>Müşteri Detay</h1>

<p>
  <a class="btn btn-outline-dark btn-sm" href="/Musteriler">← Müşteriler</a>
</p>

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:900px;">
  <h3 style="margin-bottom:6px;">@Model.Musteri.AdSoyad</h3>
  <div><b>Telefon:</b> @Model.Musteri.Telefon</div>
  <div><b>Adres:</b> @(string.IsNullOrWhiteSpace(Model.Musteri.Adres) ? "-" : Model.Musteri.Adres)</div>

  <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:12px;">
    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Toplam Gelir</b>
      <div style="font-size:18px;">@Model.ToplamGelir</div>
    </div>
    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Toplam Gider</b>
      <div style="font-size:18px;">@Model.ToplamMasraf</div>
    </div>
    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Toplam Kâr</b>
      <div style="font-size:18px;">@Model.ToplamKar</div>
    </div>
  </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
  <div style="color:red; margin:10px 0;">
    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    {
      <div>@err.ErrorMessage</div>
    }
  </div>
}

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:900px;">
  <h3>Yeni İş Ekle</h3>

  <form method="post" asp-page-handler="IsEkle" asp-route-id="@Model.Musteri.Id">
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <div style="min-width:180px;">
        <label><b>Tarih</b></label><br />
        <input asp-for="IsTarih" type="date" style="padding:8px; width:180px;" />
      </div>

      <div style="flex:1; min-width:260px;">
        <label><b>İş Adı</b></label><br />
        <input asp-for="IsAdi" style="padding:8px; width:100%;" />
      </div>

      <div style="min-width:180px;">
        <label><b>Gelir</b></label><br />
        <input asp-for="IsGelir" type="number" step="0.01" style="padding:8px; width:180px;" />
      </div>
    </div>

    <div style="margin-top:10px;">
      <button type="submit" class="btn btn-dark btn-sm">İş Ekle</button>
    </div>
  </form>
</div>

<h3>İşler</h3>

@if (Model.Isler.Count == 0)
{
  <div>Henüz iş yok.</div>
}
else
{
  @foreach (var isItem in Model.Isler)
  {
    <div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:900px;">
      <div style="display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap;">
        <div>
          <b>@isItem.IsAdi</b>
          <span style="opacity:.8;">(@isItem.Tarih.ToShortDateString())</span>
        </div>

        <div>
          <span style="margin-right:12px;"><b>Gelir:</b> @isItem.Gelir</span>
          <span style="margin-right:12px;"><b>Gider:</b> @Model.IsMasrafToplamlari[isItem.Id]</span>
          <span><b>Kâr:</b> @Model.IsKarToplamlari[isItem.Id]</span>
        </div>
      </div>

      <div style="margin-top:10px;">
        <b>Gider Kalemleri</b>

        <table style="width:100%; border-collapse:collapse; margin-top:6px;">
          <thead>
            <tr>
              <th style="border-bottom:1px solid #555; text-align:left; padding:8px; width:140px;">Tarih</th>
              <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
              <th style="border-bottom:1px solid #555; text-align:left; padding:8px; width:140px;">Tutar</th>
              <th style="border-bottom:1px solid #555; padding:8px; width:110px;">İşlem</th>
            </tr>
          </thead>
          <tbody>
            @if (isItem.Masraflar.Count == 0)
            {
              <tr>
                <td colspan="4" style="padding:8px;">Henüz gider yok.</td>
              </tr>
            }
            else
            {
              @foreach (var ms in isItem.Masraflar.OrderByDescending(x => x.Tarih).ThenByDescending(x => x.Id))
              {
                <tr>
                  <td style="border-bottom:1px solid #333; padding:8px;">@ms.Tarih.ToShortDateString()</td>
                  <td style="border-bottom:1px solid #333; padding:8px;">@ms.Aciklama</td>
                  <td style="border-bottom:1px solid #333; padding:8px;">@ms.Tutar</td>
                  <td style="border-bottom:1px solid #333; padding:8px;">
                    <form method="post"
                          asp-page-handler="MasrafSil"
                          asp-route-id="@Model.Musteri.Id"
                          style="display:inline;"
                          onsubmit="return confirm('Gider silinsin mi?');">
                      <input type="hidden" name="isId" value="@isItem.Id" />
                      <input type="hidden" name="masrafId" value="@ms.Id" />
                      <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
                    </form>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>

        <div style="margin-top:10px; padding:10px; border:1px dashed #666; border-radius:10px;">
          <b>Gider Ekle</b>

          <form method="post" asp-page-handler="MasrafEkle" asp-route-id="@Model.Musteri.Id" style="margin-top:8px;">
            <input type="hidden" name="isId" value="@isItem.Id" />

            <div style="display:flex; gap:10px; flex-wrap:wrap;">
              <div style="min-width:180px;">
                <label><b>Tarih</b></label><br />
                <input name="MasrafTarih" type="date" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" style="padding:8px; width:180px;" />
              </div>

              <div style="flex:1; min-width:240px;">
                <label><b>Açıklama</b></label><br />
                <input name="MasrafAciklama" style="padding:8px; width:100%;" />
              </div>

              <div style="min-width:180px;">
                <label><b>Tutar</b></label><br />
                <input name="MasrafTutar" type="number" step="0.01" style="padding:8px; width:180px;" />
              </div>
            </div>

            <div style="margin-top:10px;">
              <button type="submit" class="btn btn-outline-dark btn-sm">Gider Ekle</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  }
}