@page "{id:int}"
@model MuhasebeTakip2.App.Pages.Musteriler.Detay.IndexModel

<h1>Müşteri Detay</h1>

@if (Model.Musteri == null)
{
    <div style="color:red;">Müşteri bulunamadı.</div>
}
else
{
    <div style="border:1px solid #444; border-radius:10px; padding:15px; max-width:600px;">
        <p><b>Ad Soyad:</b> @Model.Musteri.AdSoyad</p>
        <p><b>Telefon:</b> @Model.Musteri.Telefon</p>
        <p><b>Adres:</b> @Model.Musteri.Adres</p>
    </div>
}

<div style="margin-top:15px;">
    <a class="btn btn-outline-dark btn-sm" href="/Musteriler/Index">← Geri Dön</a>
</div>