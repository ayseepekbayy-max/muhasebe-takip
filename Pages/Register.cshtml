@page
@model MuhasebeTakip2.App.Pages.RegisterModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Kayıt Ol";
}

<div style="
    min-height:100vh; 
    display:flex; 
    align-items:center; 
    justify-content:center; 
    background: linear-gradient(to bottom, #ffffff 0%, #ffe3c5 50%, #f2a45a 100%);
    background-attachment: fixed;
    padding:30px;
">

    <div style="
        width:430px; 
        background:rgba(255,255,255,0.97); 
        border-radius:20px; 
        padding:34px; 
        box-shadow:0 18px 40px rgba(0,0,0,0.12); 
        border:1px solid #f0e1d4;
    ">

        <div style="text-align:center; margin-bottom:26px;">
            <div style="font-size:28px; font-weight:800; color:#8a4d1a;">
                ANK Mobilya Sistemleri
            </div>

            <div style="font-size:18px; font-weight:700; color:#6a3b12; margin-top:6px;">
                Kayıt Ol
            </div>

            <div style="margin-top:10px; font-size:14px; color:#777;">
                Yeni firma hesabınızı oluşturun
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Hata))
        {
            <div style="
                color:#a40000; 
                border:1px solid #e0b4b4; 
                background:#fff3f3; 
                padding:10px 12px; 
                border-radius:10px; 
                margin-bottom:16px;">
                @Model.Hata
            </div>
        }

        <form method="post">

            <div style="margin-bottom:16px;">
                <label asp-for="FirmaAdi" style="display:block; font-weight:700; margin-bottom:6px; color:#6a3b12;">
                    Firma Adı
                </label>

                <input asp-for="FirmaAdi"
                       style="width:100%; padding:12px; border:1px solid #d6c3b3; border-radius:12px;" />
            </div>

            <div style="margin-bottom:16px;">
                <label asp-for="KullaniciAdi" style="display:block; font-weight:700; margin-bottom:6px; color:#6a3b12;">
                    Kullanıcı Adı
                </label>

                <input asp-for="KullaniciAdi"
                       style="width:100%; padding:12px; border:1px solid #d6c3b3; border-radius:12px;" />
            </div>

            <div style="margin-bottom:20px;">
                <label asp-for="Sifre" style="display:block; font-weight:700; margin-bottom:6px; color:#6a3b12;">
                    Şifre
                </label>

                <div style="display:flex; gap:8px;">
                    <input asp-for="Sifre"
                           id="registerPassword"
                           type="password"
                           style="flex:1; padding:12px; border:1px solid #d6c3b3; border-radius:12px;" />

                    <button type="button"
                            onclick="togglePassword()"
                            style="
                                padding:12px 14px; 
                                border:1px solid #d6c3b3; 
                                border-radius:12px; 
                                background:#fff7ef; 
                                color:#8a4d1a; 
                                font-weight:700;">
                        <span id="registerToggleText">Göster</span>
                    </button>
                </div>
            </div>

            <div style="display:flex; gap:10px; margin-top:10px;">

                <button type="submit"
                        style="
                            flex:1;
                            padding:13px; 
                            border:none; 
                            border-radius:14px; 
                            background:#d67a2f; 
                            color:white; 
                            font-size:16px; 
                            font-weight:800;">
                    Kayıt Ol
                </button>

                <a href="/Login"
                   style="
                        flex:1;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        padding:13px;
                        border-radius:14px;
                        background:#8a4d1a;
                        color:white;
                        font-size:16px;
                        font-weight:800;
                        text-decoration:none;">
                    Giriş Yap
                </a>

            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            var input = document.getElementById("registerPassword");
            var text = document.getElementById("registerToggleText");

            if (input.type === "password") {
                input.type = "text";
                text.innerText = "Gizle";
            } else {
                input.type = "password";
                text.innerText = "Göster";
            }
        }
    </script>
}