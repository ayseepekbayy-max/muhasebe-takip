@page
@model MuhasebeTakip2.App.Pages.AyarlarModel

<h1>Ayarlar</h1>

@if (!string.IsNullOrWhiteSpace(Model.Mesaj))
{
    <div style="color:green; margin:10px 0;">@Model.Mesaj</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Hata))
{
    <div style="color:red; margin:10px 0;">@Model.Hata</div>
}

<div style="display:grid; gap:20px; max-width:760px;">

    <div style="border:1px solid #444; border-radius:12px; padding:16px; background:white;">
        <h3>Firma Bilgileri</h3>

        <form method="post" asp-page-handler="FirmaGuncelle">
            <div style="margin-bottom:12px;">
                <label><b>Firma Adı</b></label><br />
                <input asp-for="FirmaAdi" style="width:100%; padding:8px;" />
            </div>

            <button type="submit" class="btn btn-dark btn-sm">Firma Adını Güncelle</button>
        </form>
    </div>

    <div style="border:1px solid #444; border-radius:12px; padding:16px; background:white;">
        <h3>Kullanıcı Bilgileri</h3>

        <form method="post" asp-page-handler="KullaniciGuncelle">
            <div style="margin-bottom:12px;">
                <label><b>Kullanıcı Adı</b></label><br />
                <input asp-for="KullaniciAdi" style="width:100%; padding:8px;" />
            </div>

            <div style="margin-bottom:12px;">
                <label><b>Mevcut Şifre</b></label><br />
                <input asp-for="MevcutSifre" type="password" style="width:100%; padding:8px;" />
            </div>

            <div style="margin-bottom:12px;">
                <label><b>Yeni Şifre</b></label><br />
                <input asp-for="YeniSifre" type="password" style="width:100%; padding:8px;" />
            </div>

            <div style="margin-bottom:12px;">
                <label><b>Yeni Şifre Tekrar</b></label><br />
                <input asp-for="YeniSifreTekrar" type="password" style="width:100%; padding:8px;" />
            </div>

            <button type="submit" class="btn btn-dark btn-sm">Kullanıcı Bilgilerini Güncelle</button>
        </form>
    </div>

    <div style="border:1px solid #444; border-radius:12px; padding:16px; background:white;">
        <h3>Menü Görünürlük Ayarları</h3>
        <p style="color:#666;">Firmanız için hangi kategorilerin görüneceğini buradan açıp kapatabilirsiniz.</p>

        <form method="post" asp-page-handler="MenuKaydet">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:16px;">

                <label>
                    <input asp-for="MenuCariKartlar" type="checkbox" />
                    Cari Kartlar
                </label>

                <label>
                    <input asp-for="MenuKasa" type="checkbox" />
                    Kasa
                </label>

                <label>
                    <input asp-for="MenuRaporlar" type="checkbox" />
                    Raporlar
                </label>

                <label>
                    <input asp-for="MenuCalisanlar" type="checkbox" />
                    Çalışanlar
                </label>

                <label>
                    <input asp-for="MenuMusteriler" type="checkbox" />
                    Müşteriler
                </label>

                <label>
                    <input asp-for="MenuStoklar" type="checkbox" />
                    Stok
                </label>

                <label>
                    <input asp-for="MenuMaliyet" type="checkbox" />
                    Maliyet
                </label>

                <label>
                    <input asp-for="MenuCekler" type="checkbox" />
                    Çekler
                </label>
            </div>

            <div style="margin-top:20px;">
                <button type="submit" class="btn btn-dark btn-sm">Menü Ayarlarını Kaydet</button>
            </div>
        </form>
    </div>
</div>