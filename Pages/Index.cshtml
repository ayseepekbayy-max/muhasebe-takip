@page
@model MuhasebeTakip2.App.Pages.IndexModel
@using MuhasebeTakip2.App.Models

@{
    ViewData["Title"] = "Kasa Paneli";
}

<div style="display:grid; gap:24px;">

    <!-- ÜST PANEL -->
    <div style="
        background: linear-gradient(135deg, #f8f5f1, #eee7df);
        border:1px solid #eadfd4;
        color:#3f2d20;
        border-radius:24px;
        padding:28px 30px;
        display:flex;
        justify-content:space-between;
        align-items:center;
        gap:20px;
        flex-wrap:wrap;
    ">
        <div>
            <div style="font-size:14px; margin-bottom:8px; color:#8a4b21;">Genel Durum</div>
            <h1 style="margin:0; font-size:32px; font-weight:800;">Kasa Paneli</h1>
            <div style="margin-top:10px; font-size:15px; color:#6b4a32;">
                Güncel finansal durumunuzu ve son hareketleri buradan takip edebilirsiniz.
            </div>
        </div>

        <div style="
            background:#ffffff;
            border:1px solid #eadfd4;
            border-radius:20px;
            padding:18px 22px;
        ">
            <div style="font-size:13px; color:#8a4b21;">Kasa Bakiye</div>
            <div style="font-size:32px; font-weight:800; color:#b4531a;">
                @Model.KasaBakiye.ToString("N2") ₺
            </div>
        </div>
    </div>

    <!-- BUTONLAR -->
    <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/Kasa/HareketEkle" style="
            background:#c9733d;
            color:white;
            padding:12px 18px;
            border-radius:14px;
            font-weight:700;
            text-decoration:none;
        ">
            + Kasa Hareketi Ekle
        </a>

        <a href="/CariKartlar" style="
            background:#fcfaf8;
            border:1px solid #e5d7ca;
            color:#6b4a32;
            padding:12px 18px;
            border-radius:14px;
            font-weight:700;
            text-decoration:none;
        ">
            Cari Kartlara Git
        </a>

        <a href="/Calisanlar" style="
            background:#fcfaf8;
            border:1px solid #e5d7ca;
            color:#6b4a32;
            padding:12px 18px;
            border-radius:14px;
            font-weight:700;
            text-decoration:none;
        ">
            Çalışanlara Git
        </a>

        <a href="/Raporlar" style="
            background:#fcfaf8;
            border:1px solid #e5d7ca;
            color:#6b4a32;
            padding:12px 18px;
            border-radius:14px;
            font-weight:700;
            text-decoration:none;
        ">
            Raporları Aç
        </a>
    </div>

    <!-- KARTLAR -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:18px;">

        <div style="background:#ffffff; border:1px solid #ebe5de; border-radius:20px; padding:22px;">
            <div style="color:#8a4b21;">Bugün Giriş</div>
            <div style="font-size:30px; font-weight:800; color:#166534;">
                @Model.BugunGiris.ToString("N2") ₺
            </div>
        </div>

        <div style="background:#ffffff; border:1px solid #ebe5de; border-radius:20px; padding:22px;">
            <div style="color:#8a4b21;">Bugün Çıkış</div>
            <div style="font-size:30px; font-weight:800; color:#b91c1c;">
                @Model.BugunCikis.ToString("N2") ₺
            </div>
        </div>

        <div style="background:#ffffff; border:1px solid #ebe5de; border-radius:20px; padding:22px;">
            <div style="color:#8a4b21;">Toplam Giriş</div>
            <div style="font-size:30px; font-weight:800;">
                @Model.ToplamGiris.ToString("N2") ₺
            </div>
        </div>

        <div style="background:#ffffff; border:1px solid #ebe5de; border-radius:20px; padding:22px;">
            <div style="color:#8a4b21;">Toplam Çıkış</div>
            <div style="font-size:30px; font-weight:800;">
                @Model.ToplamCikis.ToString("N2") ₺
            </div>
        </div>

        <div style="background:#fcfaf8; border:1px solid #ebe5de; border-radius:20px; padding:22px;">
            <div style="color:#8a4b21;">Cari Sayısı</div>
            <div style="font-size:30px; font-weight:800;">
                @Model.CariSayisi
            </div>
        </div>

        <div style="background:#fcfaf8; border:1px solid #ebe5de; border-radius:20px; padding:22px;">
            <div style="color:#8a4b21;">Çalışan Sayısı</div>
            <div style="font-size:30px; font-weight:800;">
                @Model.CalisanSayisi
            </div>
        </div>
    </div>

    <!-- TABLO -->
    <div style="background:#ffffff; border:1px solid #ebe5de; border-radius:24px; padding:24px;">
        
        <div style="display:flex; justify-content:space-between; margin-bottom:16px;">
            <h3 style="color:#8a4b21;">Son Hareketler</h3>
            <a href="/Kasa/Hareketler" style="
                background:#fcfaf8;
                border:1px solid #e5d7ca;
                padding:8px 14px;
                border-radius:10px;
                text-decoration:none;
                color:#6b4a32;
            ">
                Tümünü Gör
            </a>
        </div>

        <table style="width:100%; border-collapse:collapse;">
            <thead>
                <tr style="background:#fdf8f4;">
                    <th>Tarih</th>
                    <th>Tip</th>
                    <th>Cari</th>
                    <th>Açıklama</th>
                    <th>Tutar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model.Hareketler)
                {
                    <tr style="border-top:1px solid #ebe5de;">
                        <td>@h.Tarih.ToString("dd.MM.yyyy")</td>
                        <td>@(h.Tip == HareketTipi.Giris ? "Giriş" : "Çıkış")</td>
                        <td>@(h.CariKart?.Unvan ?? "-")</td>
                        <td>@h.Aciklama</td>
                        <td>@h.Tutar.ToString("N2") ₺</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>