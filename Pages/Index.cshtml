@page
@using MuhasebeTakip2.App.Models
@model MuhasebeTakip2.App.Pages.IndexModel
@{
    ViewData["Title"] = "Kasa";
}

<h1>Kasa</h1>

<div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:20px;">

    <div style="padding:16px; border:1px solid #444; border-radius:10px; min-width:240px;">
        <div style="font-weight:700; margin-bottom:8px;">Bugün Giriş</div>
        <div style="font-size:20px;">@Model.BugunGiris.ToString("N2")</div>
    </div>

    <div style="padding:16px; border:1px solid #444; border-radius:10px; min-width:240px;">
        <div style="font-weight:700; margin-bottom:8px;">Bugün Çıkış</div>
        <div style="font-size:20px;">@Model.BugunCikis.ToString("N2")</div>
    </div>

    <div style="padding:16px; border:1px solid #444; border-radius:10px; min-width:240px;">
        <div style="font-weight:700; margin-bottom:8px;">Bu Ay Giriş</div>
        <div style="font-size:20px;">@Model.BuAyGiris.ToString("N2")</div>
    </div>

    <div style="padding:16px; border:1px solid #444; border-radius:10px; min-width:240px;">
        <div style="font-weight:700; margin-bottom:8px;">Bu Ay Çıkış</div>
        <div style="font-size:20px;">@Model.BuAyCikis.ToString("N2")</div>
    </div>

    <div style="padding:16px; border:1px solid #444; border-radius:10px; min-width:240px;">
        <div style="font-weight:700; margin-bottom:8px;">Kasa Bakiye</div>
        <div style="font-size:20px;">@Model.KasaBakiye.ToString("N2")</div>
    </div>

    <div style="padding:16px; border:1px solid #444; border-radius:10px; min-width:240px;">
        <div style="font-weight:700; margin-bottom:8px;">Cari Sayısı</div>
        <div style="font-size:20px;">@Model.CariSayisi</div>
    </div>

    <div style="padding:16px; border:1px solid #444; border-radius:10px; min-width:240px;">
        <div style="font-weight:700; margin-bottom:8px;">Çalışan Sayısı</div>
        <div style="font-size:20px;">@Model.CalisanSayisi</div>
    </div>

</div>

<div style="margin-top:30px;">
    <h3>Son 10 Kasa Hareketi</h3>

    <table style="width:100%; border-collapse:collapse; margin-top:12px;">
        <thead>
            <tr>
                <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tarih</th>
                <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tip</th>
                <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tutar</th>
                <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Cari</th>
                <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.SonHareketler.Count == 0)
            {
                <tr>
                    <td colspan="5" style="padding:8px;">Henüz hareket yok.</td>
                </tr>
            }
            else
            {
                @foreach (var h in Model.SonHareketler)
                {
                    <tr>
                        <td style="border-bottom:1px solid #ddd; padding:8px;">
                            @h.Tarih.ToString("dd.MM.yyyy")
                        </td>
                        <td style="border-bottom:1px solid #ddd; padding:8px;">
                            @(h.Tip == HareketTipi.Giris ? "Giriş" : "Çıkış")
                        </td>
                        <td style="border-bottom:1px solid #ddd; padding:8px;">
                            @h.Tutar.ToString("N2")
                        </td>
                        <td style="border-bottom:1px solid #ddd; padding:8px;">
                            @(h.CariKart != null ? h.CariKart.Unvan : "-")
                        </td>
                        <td style="border-bottom:1px solid #ddd; padding:8px;">
                            @h.Aciklama
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>