@page
@using MuhasebeTakip2.App.Models
@model MuhasebeTakip2.App.Pages.IndexModel

<h1>Dashboard</h1>

@if (!string.IsNullOrWhiteSpace(Model.SayfaHata))
{
    <div style="color:red; margin:10px 0; padding:12px; border:1px solid #fecaca; background:#fef2f2; border-radius:12px;">
        @Model.SayfaHata
    </div>
}

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px; margin-top:20px;">

    <div style="background:white; border:1px solid #e2e8f0; border-radius:18px; padding:18px; box-shadow:0 10px 30px rgba(15,23,42,0.06);">
        <div style="font-size:14px; color:#64748b; margin-bottom:8px;">Bugünkü Giriş</div>
        <div style="font-size:28px; font-weight:800; color:#312e81;">@Model.BugunGiris</div>
    </div>

    <div style="background:white; border:1px solid #e2e8f0; border-radius:18px; padding:18px; box-shadow:0 10px 30px rgba(15,23,42,0.06);">
        <div style="font-size:14px; color:#64748b; margin-bottom:8px;">Bugünkü Çıkış</div>
        <div style="font-size:28px; font-weight:800; color:#dc2626;">@Model.BugunCikis</div>
    </div>

    <div style="background:white; border:1px solid #e2e8f0; border-radius:18px; padding:18px; box-shadow:0 10px 30px rgba(15,23,42,0.06);">
        <div style="font-size:14px; color:#64748b; margin-bottom:8px;">Bu Ay Giriş</div>
        <div style="font-size:28px; font-weight:800; color:#312e81;">@Model.BuAyGiris</div>
    </div>

    <div style="background:white; border:1px solid #e2e8f0; border-radius:18px; padding:18px; box-shadow:0 10px 30px rgba(15,23,42,0.06);">
        <div style="font-size:14px; color:#64748b; margin-bottom:8px;">Bu Ay Çıkış</div>
        <div style="font-size:28px; font-weight:800; color:#dc2626;">@Model.BuAyCikis</div>
    </div>

</div>

<div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; margin-top:24px; align-items:start;">

    <div style="display:grid; gap:20px;">

        <div style="background:white; border:1px solid #e2e8f0; border-radius:18px; padding:20px; box-shadow:0 10px 30px rgba(15,23,42,0.06);">
            <h3 style="margin-top:0;">Kasa Özeti</h3>

            <div style="margin-top:18px; padding:18px; border-radius:16px; background:linear-gradient(135deg,#6366f1,#4f46e5); color:white;">
                <div style="font-size:14px; opacity:0.95;">Güncel Kasa Bakiye</div>
                <div style="font-size:30px; font-weight:800; margin-top:8px;">@Model.KasaBakiye</div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:16px;">
                <div style="padding:16px; border:1px solid #e2e8f0; border-radius:14px; background:#f8fafc;">
                    <div style="font-size:14px; color:#64748b; margin-bottom:6px;">Cari Sayısı</div>
                    <div style="font-size:24px; font-weight:800; color:#312e81;">@Model.CariSayisi</div>
                </div>

                <div style="padding:16px; border:1px solid #e2e8f0; border-radius:14px; background:#f8fafc;">
                    <div style="font-size:14px; color:#64748b; margin-bottom:6px;">Çalışan Sayısı</div>
                    <div style="font-size:24px; font-weight:800; color:#312e81;">@Model.CalisanSayisi</div>
                </div>
            </div>
        </div>

        <div style="background:white; border:1px solid #e2e8f0; border-radius:18px; padding:20px; box-shadow:0 10px 30px rgba(15,23,42,0.06);">
            <h3 style="margin-top:0;">Son Kasa Hareketleri</h3>

            @if (Model.SonHareketler.Count == 0)
            {
                <div style="margin-top:16px; color:#64748b;">Henüz hareket yok.</div>
            }
            else
            {
                <table style="width:100%; border-collapse:collapse; margin-top:14px;">
                    <thead>
                        <tr>
                            <th style="padding:10px; border-bottom:1px solid #e2e8f0; text-align:left;">Tarih</th>
                            <th style="padding:10px; border-bottom:1px solid #e2e8f0; text-align:left;">Tip</th>
                            <th style="padding:10px; border-bottom:1px solid #e2e8f0; text-align:left;">Tutar</th>
                            <th style="padding:10px; border-bottom:1px solid #e2e8f0; text-align:left;">Cari</th>
                            <th style="padding:10px; border-bottom:1px solid #e2e8f0; text-align:left;">Açıklama</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model.SonHareketler)
                        {
                            <tr>
                                <td style="padding:10px; border-bottom:1px solid #eef2f7;">@h.Tarih.ToString("dd.MM.yyyy")</td>
                                <td style="padding:10px; border-bottom:1px solid #eef2f7;">
                                    @(h.Tip == HareketTipi.Giris ? "Giriş" : "Çıkış")
                                </td>
                                <td style="padding:10px; border-bottom:1px solid #eef2f7; font-weight:700; color:@(h.Tip == HareketTipi.Giris ? "#16a34a" : "#dc2626");">
                                    @h.Tutar
                                </td>
                                <td style="padding:10px; border-bottom:1px solid #eef2f7;">@(h.CariKart?.Unvan ?? "-")</td>
                                <td style="padding:10px; border-bottom:1px solid #eef2f7;">@h.Aciklama</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>

    <div style="background:white; border:1px solid #e2e8f0; border-radius:18px; padding:20px; box-shadow:0 10px 30px rgba(15,23,42,0.06);">
        <h3 style="margin-top:0;">Hızlı İşlemler</h3>

        <div style="display:grid; gap:12px; margin-top:16px;">

            <a href="/Kasa/HareketEkle"
               style="display:block; text-decoration:none; background:linear-gradient(135deg,#6366f1,#4f46e5); color:white; padding:14px 16px; border-radius:14px; font-weight:700;">
                + Kasa Hareketi Ekle
            </a>

            <a href="/CariKartlar"
               style="display:block; text-decoration:none; background:#ffffff; color:#312e81; padding:14px 16px; border-radius:14px; font-weight:700; border:1px solid #e2e8f0;">
                Cari Kartlara Git
            </a>

            <a href="/Calisanlar"
               style="display:block; text-decoration:none; background:#ffffff; color:#312e81; padding:14px 16px; border-radius:14px; font-weight:700; border:1px solid #e2e8f0;">
                Çalışanlara Git
            </a>

            <a href="/Musteriler"
               style="display:block; text-decoration:none; background:#ffffff; color:#312e81; padding:14px 16px; border-radius:14px; font-weight:700; border:1px solid #e2e8f0;">
                Müşterilere Git
            </a>

            <a href="/Raporlar"
               style="display:block; text-decoration:none; background:#ffffff; color:#312e81; padding:14px 16px; border-radius:14px; font-weight:700; border:1px solid #e2e8f0;">
                Raporları Aç
            </a>

        </div>
    </div>

</div>