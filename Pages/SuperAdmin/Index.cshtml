@page
@model MuhasebeTakip2.App.Pages.SuperAdmin.IndexModel

<h1>Süper Admin</h1>

@if (!string.IsNullOrWhiteSpace(Model.Hata))
{
    <div style="color:red; margin:10px 0;">
        @Model.Hata
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Mesaj))
{
    <div style="color:green; margin:10px 0;">
        @Model.Mesaj
    </div>
}

<div style="border:1px solid #444; border-radius:12px; padding:16px; margin-top:16px; max-width:1100px;">
    <h3>Kullanıcı Rol Yönetimi</h3>

    <table style="width:100%; border-collapse:collapse; margin-top:12px;">
        <thead>
            <tr>
                <th style="padding:8px; border-bottom:1px solid #555; text-align:left;">Kullanıcı Adı</th>
                <th style="padding:8px; border-bottom:1px solid #555; text-align:left;">Firma</th>
                <th style="padding:8px; border-bottom:1px solid #555; text-align:left;">Mevcut Rol</th>
                <th style="padding:8px; border-bottom:1px solid #555; text-align:left;">Rol Güncelle</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Kullanicilar.Count == 0)
            {
                <tr>
                    <td colspan="4" style="padding:8px;">Kayıtlı kullanıcı yok.</td>
                </tr>
            }
            else
            {
                @foreach (var k in Model.Kullanicilar)
                {
                    var kullaniciAdi = (k.KullaniciAdi ?? "").Trim().ToLower();
                    var anaAdminMi = kullaniciAdi == "admin";

                    <tr>
                        <td style="padding:8px; border-bottom:1px solid #333;">
                            @k.KullaniciAdi
                            @if (anaAdminMi)
                            {
                                <span style="margin-left:6px; color:#8a4d1a; font-weight:700;">(Ana Hesap)</span>
                            }
                        </td>

                        <td style="padding:8px; border-bottom:1px solid #333;">
                            @(k.Firma?.FirmaAdi ?? "-")
                        </td>

                        <td style="padding:8px; border-bottom:1px solid #333;">
                            @(string.IsNullOrWhiteSpace(k.Rol) ? "-" : k.Rol)
                        </td>

                        <td style="padding:8px; border-bottom:1px solid #333;">
                            <form method="post" asp-page-handler="RolGuncelle" style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin:0;">
                                <input type="hidden" name="id" value="@k.Id" />

                                <select name="yeniRol" style="padding:6px 8px; min-width:160px;" @(anaAdminMi ? "disabled" : null)>
                                    @if ((k.Rol ?? "") == "SuperAdmin")
                                    {
                                        <option value="SuperAdmin" selected>SuperAdmin</option>
                                    }
                                    else
                                    {
                                        <option value="SuperAdmin">SuperAdmin</option>
                                    }

                                    @if ((k.Rol ?? "") == "Kullanici")
                                    {
                                        <option value="Kullanici" selected>Kullanici</option>
                                    }
                                    else
                                    {
                                        <option value="Kullanici">Kullanici</option>
                                    }
                                </select>

                                @if (anaAdminMi)
                                {
                                    <button type="button"
                                            class="btn btn-outline-dark btn-sm"
                                            disabled
                                            title="Ana admin hesabının rolü değiştirilemez.">
                                        Güncelle
                                    </button>
                                }
                                else
                                {
                                    <button type="submit"
                                            class="btn btn-dark btn-sm"
                                            onclick="return confirm('Kullanıcı rolü güncellensin mi?');">
                                        Güncelle
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>