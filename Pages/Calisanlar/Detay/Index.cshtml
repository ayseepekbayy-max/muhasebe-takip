@* Pages/Calisanlar/Detay/Index.cshtml *@
@page "{id:int}"
@using MuhasebeTakip2.App.Models
@model MuhasebeTakip2.App.Pages.Calisanlar.Detay.IndexModel

@if (Model.Calisan == null)
{
  <h2>Çalışan bulunamadı</h2>
  return;
}

<h1>Çalışan Detay</h1>

<p>
  <a class="btn btn-outline-dark btn-sm" href="/Calisanlar">← Çalışanlar</a>
</p>

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:820px;">
  <h3 style="margin-bottom:6px;">@Model.Calisan.AdSoyad</h3>
  <div><b>Telefon:</b> @Model.Calisan.Telefon</div>

  <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:12px;">
    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Maaş (Toplam)</b>
      <div style="font-size:18px;">@Model.ToplamMaas</div>
    </div>

    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Toplam Avans</b>
      <div style="font-size:18px;">@Model.ToplamAvans</div>
    </div>

    <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
      <b>Kalan (Maaş - Avans)</b>
      <div style="font-size:18px;">@Model.Kalan</div>
    </div>
  </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
  <div style="color:red; margin:10px 0;">
    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    {
      <div>@err.ErrorMessage</div>
    }
  </div>
}

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:820px;">
  <h3>Kayıt Ekle</h3>

  <form method="post">
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <div style="min-width:180px;">
        <label><b>Tarih</b></label><br />
        <input asp-for="Tarih" type="date" style="padding:8px; width:180px;" />
      </div>

      <div style="min-width:180px;">
        <label><b>Tutar</b></label><br />
        <input asp-for="Tutar" type="number" step="0.01" style="padding:8px; width:180px;" />
      </div>

      <div style="flex:1; min-width:240px;">
        <label><b>Açıklama</b></label><br />
        <input asp-for="Aciklama" style="padding:8px; width:100%;" />
      </div>
    </div>

    <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
      <button type="submit" asp-page-handler="Avans" class="btn btn-outline-dark btn-sm">Avans Ekle</button>
      <button type="submit" asp-page-handler="Maas" class="btn btn-dark btn-sm">Maaş Ekle</button>
    </div>
  </form>
</div>

<h3>Kayıtlar</h3>

<table style="width:100%; border-collapse:collapse;">
  <thead>
    <tr>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tarih</th>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tip</th>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tutar</th>
      <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
      <th style="border-bottom:1px solid #555; padding:8px; width:120px;">İşlem</th>
    </tr>
  </thead>

  <tbody>
    @if (Model.Kayitlar.Count == 0)
    {
      <tr><td colspan="5" style="padding:8px;">Henüz kayıt yok.</td></tr>
    }
    else
    {
      @foreach (var k in Model.Kayitlar)
      {
        <tr>
          <td style="border-bottom:1px solid #333; padding:8px;">@k.Tarih.ToShortDateString()</td>
          <td style="border-bottom:1px solid #333; padding:8px;">
            @(k.Tip == CalisanHareketTipi.Avans ? "Avans" : "Maaş")
          </td>
          <td style="border-bottom:1px solid #333; padding:8px;">@k.Tutar</td>
          <td style="border-bottom:1px solid #333; padding:8px;">@k.Aciklama</td>
          <td style="border-bottom:1px solid #333; padding:8px;">
            <form method="post"
                  asp-page-handler="Sil"
                  asp-route-id="@Model.Calisan.Id"
                  style="display:inline;"
                  onsubmit="return confirm('Kayıt silinsin mi?');">
              <input type="hidden" name="id2" value="@k.Id" />
              <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
            </form>
          </td>
        </tr>
      }
    }
  </tbody>
</table>