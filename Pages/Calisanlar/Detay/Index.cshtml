@page "{id:int}"
@using MuhasebeTakip2.App.Models
@model MuhasebeTakip2.App.Pages.Calisanlar.Detay.IndexModel

@if (Model.Calisan == null)
{
    <h2>Çalışan bulunamadı</h2>
    return;
}

<h1>Çalışan Detay</h1>

<p>
    <a class="btn btn-outline-dark btn-sm" href="/Calisanlar">← Çalışanlar</a>
</p>

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:980px;">
    <h3 style="margin-bottom:6px;">@Model.Calisan.AdSoyad</h3>
    <div><b>Telefon:</b> @Model.Calisan.Telefon</div>

    <div style="margin-top:10px;">
        <b>Maaş Dönemi:</b>
        @Model.DonemBaslangic.ToString("dd.MM.yyyy") - @Model.DonemBitis.ToString("dd.MM.yyyy")
    </div>

    <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:12px;">
        <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
            <b>Bu Dönem Maaş</b>
            <div style="font-size:18px;">@Model.ToplamMaas.ToString("N2")</div>
        </div>

        <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
            <b>Bu Dönem Avans</b>
            <div style="font-size:18px;">@Model.ToplamAvans.ToString("N2")</div>
        </div>

        <div style="padding:10px; border:1px solid #444; border-radius:8px; min-width:220px;">
            <b>Kalan Maaş</b>
            <div style="font-size:18px;">@Model.Kalan.ToString("N2")</div>
        </div>
    </div>

    <form method="post" asp-page-handler="Odendi" asp-route-id="@Model.Calisan.Id" style="margin-top:16px;"
          onsubmit="return confirm('Bu dönem maaşı ödendi olarak arşivlensin mi?');">
        <button type="submit" class="btn btn-success btn-sm">Maaş Ödendi ve Arşivle</button>
    </form>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div style="color:red; margin:10px 0;">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </div>
}

<div style="border:1px solid #444; border-radius:10px; padding:12px; margin:12px 0; max-width:980px;">
    <h3>Kayıt Ekle</h3>

    <form method="post">
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <div style="min-width:180px;">
                <label><b>Tarih</b></label><br />
                <input asp-for="Tarih" type="date" style="padding:8px; width:180px;" />
            </div>

            <div style="min-width:180px;">
                <label><b>Tutar</b></label><br />
                <input asp-for="Tutar" type="number" step="0.01" style="padding:8px; width:180px;" />
            </div>

            <div style="flex:1; min-width:240px;">
                <label><b>Açıklama</b></label><br />
                <input asp-for="Aciklama" style="padding:8px; width:100%;" />
            </div>
        </div>

        <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
            <button type="submit" asp-page-handler="Avans" class="btn btn-outline-dark btn-sm">Avans Ekle</button>
            <button type="submit" asp-page-handler="Maas" class="btn btn-dark btn-sm">Maaş Ekle</button>
        </div>
    </form>
</div>

<h3>Aktif Kayıtlar</h3>

<table style="width:100%; border-collapse:collapse; margin-bottom:30px;">
    <thead>
        <tr>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tarih</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tip</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tutar</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
            <th style="border-bottom:1px solid #555; padding:8px; width:120px;">İşlem</th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Kayitlar.Count == 0)
        {
            <tr>
                <td colspan="5" style="padding:8px;">Aktif kayıt yok.</td>
            </tr>
        }
        else
        {
            @foreach (var k in Model.Kayitlar)
            {
                <tr>
                    <td style="border-bottom:1px solid #333; padding:8px;">@k.Tarih.ToString("dd.MM.yyyy")</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">
                        @(k.Tip == CalisanHareketTipi.Avans ? "Avans" : "Maaş")
                    </td>
                    <td style="border-bottom:1px solid #333; padding:8px;">@k.Tutar.ToString("N2")</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">@k.Aciklama</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">
                        <form method="post"
                              asp-page-handler="Sil"
                              asp-route-id="@Model.Calisan.Id"
                              style="display:inline;"
                              onsubmit="return confirm('Kayıt silinsin mi?');">
                            <input type="hidden" name="id2" value="@k.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<h3>Maaş Arşivi</h3>

<table style="width:100%; border-collapse:collapse;">
    <thead>
        <tr>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Dönem</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Maaş</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Avans</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Kalan</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Ödeme Tarihi</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
            <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">İşlem</th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Arsivler.Count == 0)
        {
            <tr>
                <td colspan="7" style="padding:8px;">Henüz arşiv kaydı yok.</td>
            </tr>
        }
        else
        {
            @foreach (var a in Model.Arsivler)
            {
                <tr>
                    <td style="border-bottom:1px solid #333; padding:8px;">
                        @a.DonemBaslangic.ToString("dd.MM.yyyy") - @a.DonemBitis.ToString("dd.MM.yyyy")
                    </td>
                    <td style="border-bottom:1px solid #333; padding:8px;">@a.ToplamMaas.ToString("N2")</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">@a.ToplamAvans.ToString("N2")</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">@a.KalanMaas.ToString("N2")</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">@a.OdemeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">@a.Aciklama</td>
                    <td style="border-bottom:1px solid #333; padding:8px;">
                        <a class="btn btn-outline-primary btn-sm"
                           href="/Calisanlar/Detay/@Model.Calisan.Id?arsivId=@a.Id">
                            Detayları Gör
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@if (Model.SeciliArsivId.HasValue)
{
    <div style="margin-top:30px; border:1px solid #444; border-radius:10px; padding:12px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap;">
            <h3 style="margin:0;">Arşiv Detay Kayıtları</h3>
            <a class="btn btn-outline-secondary btn-sm" href="/Calisanlar/Detay/@Model.Calisan.Id">Detayı Kapat</a>
        </div>

        <table style="width:100%; border-collapse:collapse; margin-top:15px;">
            <thead>
                <tr>
                    <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tarih</th>
                    <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tip</th>
                    <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Tutar</th>
                    <th style="border-bottom:1px solid #555; text-align:left; padding:8px;">Açıklama</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.SeciliArsivDetaylari.Count == 0)
                {
                    <tr>
                        <td colspan="4" style="padding:8px;">Bu arşive ait detay kayıt bulunamadı.</td>
                    </tr>
                }
                else
                {
                    @foreach (var d in Model.SeciliArsivDetaylari)
                    {
                        <tr>
                            <td style="border-bottom:1px solid #333; padding:8px;">@d.Tarih.ToString("dd.MM.yyyy")</td>
                            <td style="border-bottom:1px solid #333; padding:8px;">
                                @(d.Tip == CalisanHareketTipi.Avans ? "Avans" : "Maaş")
                            </td>
                            <td style="border-bottom:1px solid #333; padding:8px;">@d.Tutar.ToString("N2")</td>
                            <td style="border-bottom:1px solid #333; padding:8px;">@d.Aciklama</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}